<!-- HEADER -->
<header>
  <a href="index.html" class="logo">
    <i class="bi bi-check2-square"></i> Taskly
  </a>
  <nav class="nav-links">
    <a href="tasks.html" class="active">
      <i class="bi bi-list-task"></i> Tâches
    </a>
    <a href="dashboard.html">
      <i class="bi bi-bar-chart-line"></i> Dashboard
    </a>
    <a href="share.html">
      <i class="bi bi-share"></i> Partage
    </a>
  </nav>
  
  <div class="header-right">
    {% if not app.user %}
    <twig:BootstrapButton 
      type="outline"
      text="Se connecter" 
      :link="path('app_login')" 
      style="font-size:13px; padding:7px 16px;"
      outlined="true"
      icon="bi bi-box-arrow-in-right"
    />
    {% else %}
      <twig:BootstrapButton 
        type="outline"
        text="Se déconnecter" 
        :link="path('app_logout')" 
        style="font-size:13px; padding:7px 16px;"
        icon="bi bi-box-arrow-right"
        outlined="true"
      />
      {% endif %}
    </div>
      {% if app.user %}
    <div class="btn-notif">
      <i class="bi bi-bell"></i>
      <span class="notif-dot"></span>
    </div>    
      <twig:BootstrapButton 
      type="outline"
      text="Alex L." 
      link=""
      style="font-size:10px; color:#6b7280;"
      outlined="true"
      icon="bi bi-chevron-down"
    />
  </div>
  {% endif %}
</header>